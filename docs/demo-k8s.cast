{"version": 2, "width": 100, "height": 40, "timestamp": 1775905605, "env": {"SHELL": "/bin/bash", "TERM": "xterm-256color"}, "title": "k8s4claw: Deploy AI Agent on Kubernetes"}
[0.008734, "o", "\u001b[H\u001b[2J\u001b[3J"]
[0.009602, "o", "\r\n\u001b[1;36m╔══════════════════════════════════════════════════════╗\u001b[0m\r\n\u001b[1;36m║   k8s4claw — AI Agent Runtime on Kubernetes          ║\u001b[0m\r\n\u001b[1;36m║   Demo: Deploy an agent on a real K8s cluster         ║\u001b[0m\r\n\u001b[1;36m╚══════════════════════════════════════════════════════╝\u001b[0m\r\n"]
[2.010665, "o", "\r\n"]
[2.010973, "o", "\u001b[1;33m▸ Step 1: Create a Kubernetes cluster (kind)\u001b[0m\r\n"]
[3.013081, "o", "\r\n\u001b[1;32m$\u001b[0m kind create cluster --name k8s4claw-demo --wait 60s 2>&1 | tail -4\r\n"]
[37.033331, "o", "\r\nkubectl cluster-info --context kind-k8s4claw-demo\r\n\r\nHave a question, bug, or feature request? Let us know! https://kind.sigs.k8s.io/#community 🙂\r\n"]
[38.036002, "o", "\r\n"]
[38.036098, "o", "\u001b[1;33m▸ Step 2: Build and load OpenClaw runtime image\u001b[0m\r\n"]
[39.038722, "o", "\r\n\u001b[1;32m$\u001b[0m docker build -t k8s4claw-openclaw:dev -f runtimes/openclaw/Dockerfile runtimes/openclaw/ 2>&1 | tail -2\r\n"]
[41.708478, "o", "#14 naming to docker.io/library/k8s4claw-openclaw:dev done\r\n#14 DONE 0.0s\r\n"]
[42.711506, "o", "\r\n\u001b[1;32m$\u001b[0m kind load docker-image k8s4claw-openclaw:dev --name k8s4claw-demo 2>&1 | tail -1\r\n"]
[45.139986, "o", "Image: \"k8s4claw-openclaw:dev\" with ID \"sha256:d77fa1cd6b22fbaa19e444e10db603961cf01044a7c7864c9c9eae84cc29c667\" not yet present on node \"k8s4claw-demo-control-plane\", loading...\r\n"]
[46.142327, "o", "\r\n\u001b[1;33m▸ Step 3: Install k8s4claw CRDs\u001b[0m\r\n"]
[47.145305, "o", "\r\n\u001b[1;32m$\u001b[0m kubectl apply -f config/crd/bases/\r\n"]
[47.78719, "o", "customresourcedefinition.apiextensions.k8s.io/clawchannels.claw.prismer.ai created\r\n"]
[47.824848, "o", "customresourcedefinition.apiextensions.k8s.io/claws.claw.prismer.ai created\r\n"]
[47.850933, "o", "customresourcedefinition.apiextensions.k8s.io/clawselfconfigs.claw.prismer.ai created\r\n"]
[48.857779, "o", "\r\n\u001b[1;33m▸ Step 4: Deploy an AI agent\u001b[0m\r\n"]
[49.862425, "o", "\u001b[1;32m$\u001b[0m cat demo-agent.yaml\r\n"]
[50.164051, "o", "\u001b[0;37m  apiVersion: apps/v1\r\n  kind: StatefulSet\r\n"]
[50.16429, "o", "  metadata:\r\n    name: my-agent\r\n    labels:\r\n      claw.prismer.ai/runtime: openclaw\r\n"]
[50.164397, "o", "  spec:\r\n    containers:\r\n      - name: runtime\r\n        image: k8s4claw-openclaw:dev\r\n"]
[50.164466, "o", "        env:\r\n          - OPENCLAW_MODE: mock\u001b[0m\r\n"]
[51.16734, "o", "\r\n\u001b[1;32m$\u001b[0m kubectl apply -f /tmp/demo-agent.yaml\r\n"]
[51.85012, "o", "statefulset.apps/my-agent created\r\n"]
[51.879021, "o", "service/my-agent created\r\n"]
[52.889421, "o", "\r\n\u001b[1;33m▸ Step 5: Watch the agent come up\u001b[0m\r\n"]
[53.8918, "o", "\r\n\u001b[1;32m$\u001b[0m kubectl wait --for=condition=ready pod/my-agent-0 --timeout=30s\r\n"]
[63.743334, "o", "pod/my-agent-0 condition met\r\n"]
[64.749345, "o", "\r\n\u001b[1;32m$\u001b[0m kubectl get pods,svc\r\n"]
[65.321175, "o", "NAME             READY   STATUS    RESTARTS   AGE\r\npod/my-agent-0   1/1     Running   0          13s\r\n"]
[65.32151, "o", "\r\nNAME                 TYPE        CLUSTER-IP     EXTERNAL-IP   PORT(S)     AGE"]
[65.321544, "o", "\r\nservice/kubernetes   ClusterIP   10.96.0.1      <none>        443/TCP     "]
[65.321716, "o", "50s\r\nservice/my-agent     ClusterIP"]
[65.32174, "o", "   10.96.181.46   <none>        18900/TCP   13s\r\n"]
[66.326222, "o", "\r\n\u001b[1;33m▸ Step 6: Chat with the agent via WebSocket\u001b[0m\r\n"]
[69.441478, "o", "  \u001b[1;32m→ User:\u001b[0m Hello! What can you do?\r\n"]
[69.443068, "o", "  \u001b[1;34m← Agent:\u001b[0m\r\n    Hello! I'm an OpenClaw agent running on Kubernetes, managed by k8s4claw. How can I help your team today?\r\n\r\n"]
[70.444447, "o", "  \u001b[1;32m→ User:\u001b[0m Tell me about k8s4claw\r\n"]
[70.44676, "o", "  \u001b[1;34m← Agent:\u001b[0m\r\n    k8s4claw manages AI agent runtimes on Kubernetes. It handles:\r\n    - StatefulSet lifecycle\r\n    - IPC Bus message routing (WAL + DLQ)\r\n    - Channel sidecars (Slack, Discord, Webhook)\r\n    - Auto-updates with health checks and circuit breaker\r\n    - PVC persistence and CSI snapshots\r\n\r\n"]
[71.44817, "o", "  \u001b[1;32m→ User:\u001b[0m What is your status?\r\n"]
[71.450381, "o", "  \u001b[1;34m← Agent:\u001b[0m\r\n    All systems operational:\r\n"]
[71.450481, "o", "    - Runtime: OpenClaw v0.1.0\r\n    - IPC Bus: Connected\r\n    - Channels: 1 active (slack-team)\r\n    - Uptime: 2h 15m\r\n    - Messages processed: 42\r\n\r\n"]
[73.4987, "o", "\r\n\u001b[1;33m▸ Step 7: Agent logs\u001b[0m\r\n"]
[74.501759, "o", "\r\n\u001b[1;32m$\u001b[0m kubectl logs my-agent-0 --tail 5\r\n"]
[75.100319, "o", "{\"time\":\"2026-04-11T11:07:55.055367393Z\",\"level\":\"INFO\",\"msg\":\"IPC bus bridge connected\"}\r\n{\"time\":\"2026-04-11T11:07:55.057095782Z\",\"level\":\"INFO\",\"msg\":\"processing message\",\"msgId\":\"demo--3393568455032312713\",\"user\":\"alice\",\"text_len\":23}\r\n{\"time\":\"2026-04-11T11:07:56.060756609Z\",\"level\":\"INFO\",\"msg\":\"processing message\",\"msgId\":\"demo--6992063193515370246\",\"user\":\"alice\",\"text_len\":22}\r\n{\"time\":\"2026-04-11T11:07:57.064406113Z\",\"level\":\"INFO\",\"msg\":\"processing message\",\"msgId\":\"demo--3654606179791792853\",\"user\":\"alice\",\"text_len\":20}\r\n{\"time\":\"2026-04-11T11:07:58.068179723Z\",\"level\":\"INFO\",\"msg\":\"websocket read ended\",\"error\":\"failed to get reader: received close frame: status = StatusNormalClosure and reason = \\\"\\\"\"}\r\n"]
[76.106084, "o", "\r\n\u001b[1;33m▸ Cleanup\u001b[0m\r\n"]
[77.108579, "o", "\r\n\u001b[1;32m$\u001b[0m kind delete cluster --name k8s4claw-demo 2>&1 | tail -1\r\n"]
[78.821066, "o", "Deleted nodes: [\"k8s4claw-demo-control-plane\"]\r\n"]
[79.824595, "o", "\r\n"]
[79.824855, "o", "\u001b[1;36m╔══════════════════════════════════════════════════════╗\u001b[0m\r\n\u001b[1;36m║   Done! From zero to AI agent on K8s in 2 minutes.   ║\u001b[0m\r\n\u001b[1;36m║                                                      ║\u001b[0m\r\n\u001b[1;36m║   With real Claude API:                               ║\u001b[0m\r\n"]
[79.824947, "o", "\u001b[1;36m║     -e ANTHROPIC_API_KEY=sk-ant-xxx                   ║\u001b[0m\r\n\u001b[1;36m║                                                      ║\u001b[0m\r\n\u001b[1;36m║   github.com/Prismer-AI/k8s4claw                     ║\u001b[0m\r\n"]
[79.825059, "o", "\u001b[1;36m╚══════════════════════════════════════════════════════╝\u001b[0m\r\n"]
