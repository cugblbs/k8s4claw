[0.01011, "o", "\r\n\u001b[1;36mв•”в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•—\u001b[0m\r\n\u001b[1;36mв•‘   k8s4claw вЂ” AI Agent Runtime on Kubernetes      в•‘\u001b[0m\r\n\u001b[1;36mв•‘   Demo: OpenClaw runtime in mock mode            в•‘\u001b[0m\r\n\u001b[1;36mв•љв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ќ\u001b[0m\r\n"]
[2.012178, "o", "\r\n\u001b[1;33mв–ё Step 1: Build the OpenClaw runtime image\u001b[0m\r\n"]
[3.015405, "o", "\r\n\u001b[1;32m$\u001b[0m docker build -t k8s4claw-openclaw:dev -f runtimes/openclaw/Dockerfile runtimes/openclaw/ 2>&1 | tail -3\r\n"]
[4.99824, "o", "#14 writing image sha256:b8a766cc7f309e5608fce90898ad2b5b194b7c92979325a7a16e1914af0fe50d done\r\n#14 naming to docker.io/library/k8s4claw-openclaw:dev done\r\n#14 DONE 0.0s\r\n"]
[6.20139, "o", "\r\n\u001b[1;33mв–ё Step 2: Start runtime in mock mode (no API key needed)\u001b[0m\r\n"]
[7.204302, "o", "\r\n\u001b[1;32m$\u001b[0m docker run --rm -d --name demo-agent -p 18900:18900 -e OPENCLAW_MODE=mock k8s4claw-openclaw:dev\r\n"]
