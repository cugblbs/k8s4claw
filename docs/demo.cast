[18.356035, "o", "\r\n"]
[18.356279, "o", "\u001b[1;33mв–ё Step 4: Send messages via WebSocket (IPC bus protocol)\u001b[0m\r\n"]
[19.358428, "o", "\r\n\u001b[1;32m$\u001b[0m # Saying hello...\r\n"]
[19.963244, "o", "  \u001b[1;34mв†ђ Agent:\u001b[0m Hello! I'm an OpenClaw agent running on Kubernetes, managed by k8s4claw. How can I help your team today?\r\n"]
[21.464967, "o", "  \u001b[1;32mв†’ User:\u001b[0m What does k8s4claw do?\r\n"]
[21.966908, "o", "  \u001b[1;34mв†ђ Agent:\u001b[0m\r\n    k8s4claw manages AI agent runtimes on Kubernetes. It handles:\r\n    - StatefulSet lifecycle\r\n    - IPC Bus message routing (WAL + DLQ)\r\n    - Channel sidecars (Slack, Discord, Webhook)\r\n    - Auto-updates with health checks and circuit breaker\r\n    - PVC persistence and CSI snapshots\r\n"]
[23.468765, "o", "  \u001b[1;32mв†’ User:\u001b[0m What's the status?\r\n"]
[23.970973, "o", "  \u001b[1;34mв†ђ Agent:\u001b[0m\r\n    All systems operational:\r\n    - Runtime: OpenClaw v0.1.0\r\n    - IPC Bus: Connected\r\n    - Channels: 1 active (slack-team)\r\n    - Uptime: 2h 15m\r\n    - Messages processed: 42\r\n"]
[26.016562, "o", "\r\n\u001b[1;33mв–ё Step 5: Clean up\u001b[0m\r\n"]
[27.019451, "o", "\r\n\u001b[1;32m$\u001b[0m docker stop demo-agent\r\n"]
[28.094423, "o", "demo-agent\r\n"]
[29.298936, "o", "\r\n\u001b[1;36mв•”в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•—\u001b[0m\r\n"]
