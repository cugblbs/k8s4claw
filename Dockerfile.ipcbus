FROM golang:1.25-alpine AS builder

WORKDIR /workspace
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -a -o /claw-ipcbus ./cmd/ipcbus/

FROM gcr.io/distroless/static:nonroot
COPY --from=builder /claw-ipcbus /claw-ipcbus
USER 65532:65532
ENTRYPOINT ["/claw-ipcbus"]
