FROM golang:1.25-alpine AS builder

WORKDIR /workspace
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -a -o /claw-channel-discord ./cmd/channel-discord/

FROM gcr.io/distroless/static:nonroot
COPY --from=builder /claw-channel-discord /claw-channel-discord
USER 65532:65532
EXPOSE 8080
ENTRYPOINT ["/claw-channel-discord"]
