FROM golang:1.25-alpine AS builder

WORKDIR /workspace
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -a -o /claw-channel-slack ./cmd/channel-slack/

FROM gcr.io/distroless/static:nonroot
COPY --from=builder /claw-channel-slack /claw-channel-slack
USER 65532:65532
EXPOSE 8080
ENTRYPOINT ["/claw-channel-slack"]
